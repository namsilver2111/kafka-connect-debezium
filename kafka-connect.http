### =============================================
### TASKS MANAGEMENT
### =============================================

### Get teams connector tasks
GET {{baseUrl}}/connectors/sqlserver-teams-source-connector/tasks

###

### Restart specific task (task 0)
POST {{baseUrl}}/connectors/sqlserver-teams-source-connector/tasks/0/restart

###

### Get task status
GET {{baseUrl}}/connectors/sqlserver-teams-source-connector/tasks/0/status

###

### =============================================
### BULK OPERATIONS
### =============================================

### Delete all source connectors
DELETE {{baseUrl}}/connectors/sqlserver-teams-source-connector

###

DELETE {{baseUrl}}/connectors/sqlserver-players-source-connector

###

DELETE {{baseUrl}}/connectors/sqlserver-squad-source-connector

###

### Delete all sink connectors
DELETE {{baseUrl}}/connectors/postgres-teams-sink-connector

###

DELETE {{baseUrl}}/connectors/postgres-players-sink-connector

###

DELETE {{baseUrl}}/connectors/postgres-squad-sink-connector

###

### =============================================
### POSTGRESQL SINK CONNECTORS
### =============================================

### =============================================
### TEAMS SINK CONNECTOR
### =============================================

### Create teams sink connector
POST {{baseUrl}}/connectors
Content-Type: application/json

{
  "name": "postgres-teams-sink-connector",
  "config": {
    "connector.class": "io.debezium.connector.jdbc.JdbcSinkConnector",
    "tasks.max": "1",
    "connection.url": "jdbc:postgresql://postgres:5432/sport",
    "connection.username": "postgres",
    "connection.password": "postgres",
    "topics": "cdc.sport.dbo.teams",
    "insert.mode": "upsert",
    "delete.enabled": "true",
    "primary.key.mode": "record_key",
    "primary.key.fields": "team_id",
    "schema.evolution": "basic",
    "table.name.format": "teams",
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "true",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "true",
    "transforms": "unwrap",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "false",
    "transforms.unwrap.delete.handling.mode": "rewrite"
  }
}

###

### Get teams sink connector status
GET {{baseUrl}}/connectors/postgres-teams-sink-connector/status

###

### Get teams sink connector config
GET {{baseUrl}}/connectors/postgres-teams-sink-connector/config

###

### Pause teams sink connector
PUT {{baseUrl}}/connectors/postgres-teams-sink-connector/pause

###

### Resume teams sink connector
PUT {{baseUrl}}/connectors/postgres-teams-sink-connector/resume

###

### Restart teams sink connector
POST {{baseUrl}}/connectors/postgres-teams-sink-connector/restart

###

### Delete teams sink connector
DELETE {{baseUrl}}/connectors/postgres-teams-sink-connector

###

